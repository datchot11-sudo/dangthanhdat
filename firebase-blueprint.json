{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A gaming console or accessory for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product." },
        "description": { "type": "string", "description": "Detailed description." },
        "price": { "type": "number", "description": "Price in VND." },
        "category": { "type": "string", "description": "Category ID or name (Deprecated)." },
        "categories": { "type": "array", "items": { "type": "string" }, "description": "List of category IDs." },
        "imageUrl": { "type": "string", "description": "URL of the product image (Deprecated)." },
        "imageUrls": { "type": "array", "items": { "type": "string" }, "description": "List of product image URLs." },
        "stock": { "type": "integer", "description": "Available stock." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["name", "price", "categories", "imageUrls"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category (e.g., Nintendo Switch, PS5, Accessories).",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name." },
        "slug": { "type": "string", "description": "URL slug." }
      },
      "required": ["name", "slug"]
    },
    "Article": {
      "title": "Article",
      "description": "Gaming news or blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Article title." },
        "content": { "type": "string", "description": "Markdown content." },
        "imageUrl": { "type": "string", "description": "Featured image URL." },
        "author": { "type": "string", "description": "Author name." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "content", "imageUrl"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's email." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role." }
      },
      "required": ["email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "address": { "type": "string", "description": "Store address." },
        "phone": { "type": "string", "description": "Store phone number." },
        "email": { "type": "string", "description": "Store contact email." },
        "bankQrUrl": { "type": "string", "description": "URL of the bank QR code image." },
        "momoQrUrl": { "type": "string", "description": "URL of the Momo/ZaloPay QR code image." },
        "bannerUrl": { "type": "string", "description": "URL of the main home banner." },
        "bannerTitle": { "type": "string", "description": "Main banner title." },
        "bannerSubtitle": { "type": "string", "description": "Main banner subtitle." }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order." },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "note": { "type": "string" }
          },
          "required": ["name", "phone", "address"]
        },
        "items": { "type": "array", "description": "List of items in the order." },
        "total": { "type": "number", "description": "Total order amount." },
        "paymentMethod": { "type": "string", "enum": ["cod", "bank", "momo"] },
        "status": { "type": "string", "enum": ["pending", "received", "shipping", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerInfo", "items", "total", "paymentMethod", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Store products." },
    "/categories/{categoryId}": { "schema": "Category", "description": "Store categories." },
    "/articles/{articleId}": { "schema": "Article", "description": "Store news articles." },
    "/users/{userId}": { "schema": "User", "description": "Store user profiles." },
    "/settings/{settingId}": { "schema": "Settings", "description": "Store global settings." },
    "/orders/{orderId}": { "schema": "Order", "description": "Store customer orders." }
  }
}
